# Portable miner configuration.
# Copy this file to config.local/miner.env and adjust values per device.

COIN=DOGE
WALLET=REPLACE_WITH_YOUR_WALLET
PASSWORD=x

# Optional. Leave empty to use hostname / computer name.
WORKER_NAME=
RIG_ID=

# cpu | gpu | both
AUTOSTART_PROFILE=cpu

POOL_CPU=rx.unmineable.com:3333
ALGO_CPU=rx
XMRIG_UNIX_BIN=
XMRIG_THREADS=2
XMRIG_CPU_PRIORITY=5
XMRIG_CPU_AFFINITY=
XMRIG_PRINT_TIME=60
XMRIG_HEALTH_PRINT_TIME=60
XMRIG_DONATE_LEVEL=1
XMRIG_HUGE_PAGES_JIT=false

POOL_GPU=etchash.unmineable.com:3333
ALGO_GPU=ETCHASH
LOLMINER_UNIX_BIN=
LOL_WORKER_NAME=
LOL_API_PORT=8020
LOL_EXTRA_ARGS=--ethstratum ETHPROXY
